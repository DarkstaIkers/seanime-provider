{
  "id": "mediocrescan",
  "name": "MediocreScan",
  "description": "Manhwa provider for MediocreScan. NOTE: Requires an account created on the site (configured in the extension's settings) to work.",
  "manifestURI": "https://raw.githubusercontent.com/Jhoorodre/seanime-provider/refs/heads/master/src/mediocrescan/mediocrescan.json",
  "version": "1.0.6",
  "author": "jhoorodr",
  "type": "manga-provider",
  "language": "typescript",
  "lang": "pt-BR",
  "icon": "https://raw.githubusercontent.com/Jhoorodre/seanime-provider/master/icon/mediocrescan.png",
  "payloadURI": "https://raw.githubusercontent.com/Jhoorodre/seanime-provider/refs/heads/master/src/mediocrescan/mediocrescan.ts",
  "isDevelopment": false,
  "userConfig": {
    "requiresConfig": true,
    "version": 1,
    "fields": [
      {
        "name": "email",
        "label": "E-mail da sua conta",
        "type": "text",
        "default": ""
      },
      {
        "name": "password",
        "label": "Senha",
        "type": "text",
        "default": ""
      }
    ]
  }
}
